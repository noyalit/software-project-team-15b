# Template for the app machine (PC-B) — copy to .env next to docker-compose.app.yml.
#
#   cp .env.app.example .env   # then set POSTGRES_HOST below
#   docker compose -f docker-compose.app.yml up --build
#
# Open the UI at http://<this machine's IP>:5173.

# The app stack pins SPRING_PROFILES_ACTIVE=docker in docker-compose.app.yml, so this
# is not required here — left commented for clarity.
# SPRING_PROFILES_ACTIVE=docker

# --- Remote database ------------------------------------------------------
# REQUIRED: IP/hostname of the DB machine (PC-A) running docker-compose.db.yml.
# Compose aborts with a clear error if this is left unset.
POSTGRES_HOST=192.168.x.x
# The following must MATCH the DB machine's .env (.env.db.example).
POSTGRES_PORT=5432
POSTGRES_DB=ticketmaster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Backend --------------------------------------------------------------
# External integrations: fake (stubs) | real
EXTERNAL_MODE=fake
# Port the Spring app binds to (inside the container and the host mapping below).
SERVER_PORT=8081
BACKEND_PORT=8081

# --- UI -------------------------------------------------------------------
UI_PORT=5173
# UI dev-server proxy target — backend service name on this machine's compose network.
VITE_API_PROXY_TARGET=http://backend:8081

# --- Initial-state seeding (opt-in) --------------------------------------
# Set true ONCE against a fresh remote DB to seed it (abort-on-failure).
INIT_RUN=false
INIT_STATE_FILE=classpath:initial-state.txt
