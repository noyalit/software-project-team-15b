# Central runtime config, read by BOTH Docker Compose (native .env) and local
# `mvnw spring-boot:run` (via DotenvEnvironmentPostProcessor, which walks up to
# this file). Real shell env vars override these, e.g. `INIT_RUN=true mvnw spring-boot:run`.

# Spring profile
# Local profile: inMemory | docker | cloudsql.
# NOTE: the Docker stack always runs the 'docker' profile
SPRING_PROFILES_ACTIVE=inMemory

# External integrations: fake | real
EXTERNAL_MODE=real

# Backend
# Port the Spring app binds to (local and inside the container).
SERVER_PORT=8081

# Postgres (used by the 'docker' profile)
POSTGRES_DB=ticketmaster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Host for LOCAL docker-profile runs. In the Docker stack this is pinned to the
# 'postgres' service name in docker-compose.yml.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Docker host port mappings
BACKEND_PORT=8081
UI_PORT=5173
VITE_API_PROXY_TARGET=http://backend:8081

# Initial-state seeding (opt-in)
# true runs the initial-state file once at startup; abort-on-failure, so against
# a persistent DB re-seed only on a fresh volume (docker compose down -v).
INIT_RUN=true
INIT_STATE_FILE=classpath:initial-state.final-milestone.txt
