# Template for the DB machine (PC-A) — copy to .env next to docker-compose.db.yml.
#
#   cp .env.db.example .env
#   docker compose -f docker-compose.db.yml up -d
#
# These values must MATCH the POSTGRES_* values in the app machine's .env
# (.env.app.example), otherwise the backend can't authenticate.

POSTGRES_DB=ticketmaster
POSTGRES_USER=postgres
# SECURITY: this port is reachable from other machines on the network. Replace the
# default with a strong password (and ideally restrict the firewall to the app
# machine's IP). Do NOT ship the default 'postgres' password on a shared network.
POSTGRES_PASSWORD=postgres
# Port published on this machine for remote backends to connect to.
POSTGRES_PORT=5432
