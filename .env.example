# Storage backend toggle
# - memory: keep data in-memory (dev/testing)
# - db: persist to database
STORAGE_MODE=memory

# Database settings (used only when STORAGE_MODE=db)
DB_URL=jdbc:postgresql://localhost:5432/ticketmaster
DB_USERNAME=postgres
DB_PASSWORD=change_me

# Spring profile (optional)
SPRING_PROFILES_ACTIVE=default
