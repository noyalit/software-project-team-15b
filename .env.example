# Template for the root .env (copy to .env and adjust). Read by BOTH Docker
# Compose and local `mvnw spring-boot:run`. Real shell env vars override these.

# --- Spring profile -------------------------------------------------------
# Local profile: inMemory | docker | cloudsql.
# The Docker stack always runs the 'docker' profile (pinned in docker-compose.yml).
SPRING_PROFILES_ACTIVE=inMemory

# External integrations: fake | real
EXTERNAL_MODE=fake

# --- Backend --------------------------------------------------------------
SERVER_PORT=8081

# --- Postgres (used by the 'docker' profile) ------------------------------
POSTGRES_DB=ticketmaster
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Docker host port mappings -------------------------------------------
BACKEND_PORT=8081
UI_PORT=5173
VITE_API_PROXY_TARGET=http://backend:8081

# --- Initial-state seeding (opt-in) --------------------------------------
INIT_RUN=false
INIT_STATE_FILE=classpath:initial-state.final-milestone.txt
